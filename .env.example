DATABASE_URL=file:./local.db
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=taskmaster-files
REDIS_URL=redis://localhost:6379
ORIGIN=http://localhost:5173

# AI provider (OpenAI-compatible chat completions endpoint)
AI_PROVIDER_URL=
AI_API_KEY=
AI_MODEL=gpt-4o-mini

# adapter-node behind a reverse proxy / load balancer.
# getClientAddress() (used by rate limiting) reads the client IP from
# ADDRESS_HEADER, trusting XFF_DEPTH hops. Set these to the number of proxies
# in front of the app so the client IP cannot be spoofed.
# ADDRESS_HEADER=x-forwarded-for
# XFF_DEPTH=1
# PROTOCOL_HEADER=x-forwarded-proto
# HOST_HEADER=x-forwarded-host
# BODY_SIZE_LIMIT=512K
